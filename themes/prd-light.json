{
  "id": "prd-light",
  "name": "PRD Light",
  "background": {
    "page": "#f8fafc",
    "surface": "#ffffff",
    "elevated": "#f1f5f9",
    "inverse": "#0f172a"
  },
  "typography": {
    "fontFamily": "Inter, system-ui, sans-serif",
    "headingWeight": 700,
    "bodyWeight": 400,
    "textColor": "#0f172a",
    "mutedTextColor": "#475569",
    "lineHeight": 1.5
  },
  "buttons": {
    "radius": 10,
    "paddingY": 10,
    "paddingX": 16,
    "primaryBg": "#2563eb",
    "primaryText": "#ffffff",
    "secondaryBg": "#dbeafe",
    "secondaryText": "#1e3a8a"
  },
  "accents": {
    "brand": "#2563eb",
    "success": "#16a34a",
    "warning": "#d97706",
    "danger": "#dc2626",
    "info": "#0ea5e9"
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32
  },
  "bordersShadowsCards": {
    "borderColor": "#cbd5e1",
    "borderWidth": 1,
    "cardRadius": 14,
    "cardShadow": "0 4px 14px rgba(15, 23, 42, 0.08)",
    "focusRing": "0 0 0 3px rgba(37, 99, 235, 0.35)"
  }
}
